<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvParentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gia Control"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#202124"/>

            <TextView
                android:id="@+id/tvPairCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pair Code: —"
                android:textSize="11sp"
                android:textColor="#5E5CE6"/>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShowQr"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="QR"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textColor="#5E5CE6"
            app:backgroundTint="#EEF0FF"
            app:cornerRadius="17dp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Logout"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textColor="#80868B"
            app:backgroundTint="#F1F3F4"
            app:cornerRadius="17dp"
            style="@style/Widget.Material3.Button.TonalButton"/>

    </LinearLayout>

    <!-- Status strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/tvChildName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="No device paired"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#202124"/>

        <TextView
            android:id="@+id/tvChildStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Offline"
            android:textSize="12sp"
            android:textColor="#C5221F"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔋 —"
            android:textSize="12sp"
            android:textColor="#5F6368"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvLockState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔓"
            android:textSize="12sp"
            android:textColor="#5F6368"
            android:layout_marginEnd="8dp"/>

        <ImageView
            android:id="@+id/btnRefresh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_popup_sync"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Pairing banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPairing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EEF0FF"
                app:strokeColor="#C5CAF9"
                app:strokeWidth="1dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔗 No Child Device Connected"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#4845D2"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap QR to show your pair code. On the child device: open the child app → login → enter the pair code."
                        android:textSize="13sp"
                        android:textColor="#5F6368"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShowQrBanner"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Show QR Code"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#5E5CE6"
                        app:backgroundTint="#FFFFFF"
                        app:strokeColor="#C5CAF9"
                        app:strokeWidth="1dp"
                        app:cornerRadius="10dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Map Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📍 Live Location"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#202124"/>

                        <TextView
                            android:id="@+id/tvConnection"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Offline"
                            android:textSize="11sp"
                            android:textColor="#80868B"/>

                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/map"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"/>

                    <TextView
                        android:id="@+id/tvLastSeen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Never connected"
                        android:textSize="11sp"
                        android:textColor="#80868B"
                        android:padding="10dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Controls Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DEVICE CONTROLS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#80868B"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp"/>

                    <!-- Lock / Unlock -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLock"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="🔒 Lock"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            android:textColor="#C5221F"
                            app:backgroundTint="#FCE8E6"
                            app:cornerRadius="10dp"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.Material3.Button.TonalButton"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUnlock"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="🔓 Unlock"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            android:textColor="#137333"
                            app:backgroundTint="#E6F4EA"
                            app:cornerRadius="10dp"
                            android:layout_marginStart="6dp"
                            style="@style/Widget.Material3.Button.TonalButton"/>

                    </LinearLayout>

                    <!-- Launcher ON / OFF -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLauncherOn"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="🏠 Launcher ON"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textColor="#B06000"
                            app:backgroundTint="#FEF7E0"
                            app:cornerRadius="10dp"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.Material3.Button.TonalButton"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLauncherOff"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="🏠 Launcher OFF"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textColor="#5F6368"
                            app:backgroundTint="#F1F3F4"
                            app:cornerRadius="10dp"
                            android:layout_marginStart="6dp"
                            style="@style/Widget.Material3.Button.TonalButton"/>

                    </LinearLayout>

                    <!-- Manage Apps -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnManageApps"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:text="📱 Manage Apps"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#1A73E8"
                        app:backgroundTint="#E8F0FE"
                        app:cornerRadius="10dp"
                        android:layout_marginBottom="8dp"
                        style="@style/Widget.Material3.Button.TonalButton"/>

                    <!-- Temp Access / Set PIN -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTempAccess"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="⏱ Temp Access"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textColor="#137333"
                            app:backgroundTint="#E6F4EA"
                            app:cornerRadius="10dp"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.Material3.Button.TonalButton"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSetPin"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="🔑 Set PIN"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textColor="#1A73E8"
                            app:backgroundTint="#E8F0FE"
                            app:cornerRadius="10dp"
                            android:layout_marginStart="6dp"
                            style="@style/Widget.Material3.Button.TonalButton"/>

                    </LinearLayout>

                    <!-- Unpair -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUnpair"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:text="Unpair Device"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#80868B"
                        app:backgroundTint="#F1F3F4"
                        app:cornerRadius="10dp"
                        style="@style/Widget.Material3.Button.TonalButton"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
