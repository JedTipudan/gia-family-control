<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#111111">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvParentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gia Control"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/tvPairCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pair Code: —"
                android:textSize="11sp"
                android:textColor="#6B7280"/>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShowQr"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="QR"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textColor="#5E5CE6"
            app:backgroundTint="#1A1A2E"
            app:strokeColor="#2A2A4E"
            app:strokeWidth="1dp"
            app:cornerRadius="17dp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Logout"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textColor="#9CA3AF"
            app:backgroundTint="#1A1A1A"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp"
            app:cornerRadius="17dp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

    </LinearLayout>

    <!-- Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#111111">

        <TextView
            android:id="@+id/tvChildName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="No device paired"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvChildStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Offline"
            android:textSize="12sp"
            android:textColor="#EF4444"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔋 —"
            android:textSize="12sp"
            android:textColor="#9CA3AF"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvLockState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔓"
            android:textSize="12sp"
            android:textColor="#9CA3AF"
            android:layout_marginEnd="8dp"/>

        <ImageView
            android:id="@+id/btnRefresh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_popup_sync"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1F1F1F"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Map Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#111111"
                app:strokeColor="#1F1F1F"
                app:strokeWidth="1dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📍 Live Location"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>

                        <TextView
                            android:id="@+id/tvConnection"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Offline"
                            android:textSize="11sp"
                            android:textColor="#6B7280"/>

                    </LinearLayout>

                    <fragment
                        android:id="@+id/map"
                        android:name="com.google.android.gms.maps.SupportMapFragment"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"/>

                    <TextView
                        android:id="@+id/tvLastSeen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Never connected"
                        android:textSize="11sp"
                        android:textColor="#6B7280"
                        android:padding="10dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Controls Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#111111"
                app:strokeColor="#1F1F1F"
                app:strokeWidth="1dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DEVICE CONTROLS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#6B7280"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp"/>

                    <!-- Lock / Unlock -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLock"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="🔒 Lock"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            android:textColor="#F87171"
                            app:backgroundTint="#3B1212"
                            app:strokeColor="#5C1A1A"
                            app:strokeWidth="1dp"
                            app:cornerRadius="10dp"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUnlock"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="🔓 Unlock"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            android:textColor="#34D399"
                            app:backgroundTint="#0D2E1F"
                            app:strokeColor="#1A5C3A"
                            app:strokeWidth="1dp"
                            app:cornerRadius="10dp"
                            android:layout_marginStart="6dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"/>

                    </LinearLayout>

                    <!-- Launcher ON / OFF -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLauncherOn"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="🏠 Launcher ON"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textColor="#FBBF24"
                            app:backgroundTint="#2E2412"
                            app:strokeColor="#5C4A1A"
                            app:strokeWidth="1dp"
                            app:cornerRadius="10dp"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLauncherOff"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="🏠 Launcher OFF"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textColor="#9CA3AF"
                            app:backgroundTint="#1A1A1A"
                            app:strokeColor="#2A2A2A"
                            app:strokeWidth="1dp"
                            app:cornerRadius="10dp"
                            android:layout_marginStart="6dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"/>

                    </LinearLayout>

                    <!-- Manage Apps -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnManageApps"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:text="📱 Manage Apps"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#818CF8"
                        app:backgroundTint="#12203B"
                        app:strokeColor="#1A2E5C"
                        app:strokeWidth="1dp"
                        app:cornerRadius="10dp"
                        android:layout_marginBottom="8dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>

                    <!-- Temp Access / Set PIN -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTempAccess"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="⏱ Temp Access"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textColor="#34D399"
                            app:backgroundTint="#0D2E1F"
                            app:strokeColor="#1A5C3A"
                            app:strokeWidth="1dp"
                            app:cornerRadius="10dp"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSetPin"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="🔑 Set PIN"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textColor="#818CF8"
                            app:backgroundTint="#12203B"
                            app:strokeColor="#1A2E5C"
                            app:strokeWidth="1dp"
                            app:cornerRadius="10dp"
                            android:layout_marginStart="6dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"/>

                    </LinearLayout>

                    <!-- Unpair -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUnpair"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:text="Unpair Device"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#6B7280"
                        app:backgroundTint="#1A1A1A"
                        app:strokeColor="#2A2A2A"
                        app:strokeWidth="1dp"
                        app:cornerRadius="10dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
