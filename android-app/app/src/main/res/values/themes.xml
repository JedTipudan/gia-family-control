<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.GiaFamilyControl" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Stripe Design System - Auto Dark/Light -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryVariant">@color/accent_pressed</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/success</item>
        <item name="colorSecondaryVariant">@color/success</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowEnterTransition">@android:transition/fade</item>
        <item name="android:windowExitTransition">@android:transition/fade</item>
        
        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorTertiary">@color/text_tertiary</item>
        
        <!-- Custom attributes -->
        <item name="backgroundColor">@color/bg_primary</item>
        <item name="cardBackgroundColor">@color/bg_elevated</item>
        <item name="textColorPrimary">@color/text_primary</item>
        <item name="textColorSecondary">@color/text_secondary</item>
        <item name="drawerBackgroundColor">@color/bg_secondary</item>
    </style>

    <style name="Theme.GiaFamilyControl.LockScreen" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">#CC000000</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowShowWallpaper">false</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.GiaFamilyControl.Overlay" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/bg_elevated</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.GiaFamilyControl.Splash" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/accent_primary</item>
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
