<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.GiaFamilyControl" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#4F46E5</item>
        <item name="colorPrimaryVariant">#3730A3</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#10B981</item>
        <item name="android:windowBackground">#F3F4F6</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowEnterTransition">@android:transition/fade</item>
        <item name="android:windowExitTransition">@android:transition/fade</item>
        
        <!-- Custom attributes -->
        <item name="backgroundColor">#F3F4F6</item>
        <item name="cardBackgroundColor">#FFFFFF</item>
        <item name="textColorPrimary">#1F2937</item>
        <item name="textColorSecondary">#6B7280</item>
        <item name="drawerBackgroundColor">#FFFFFF</item>
    </style>

    <style name="Theme.GiaFamilyControl.LockScreen" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">#CC000000</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowShowWallpaper">false</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.GiaFamilyControl.Overlay" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">#EE1A1A2E</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.GiaFamilyControl.Splash" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">#4F46E5</item>
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
