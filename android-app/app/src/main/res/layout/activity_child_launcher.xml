<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0D1117">

    <!-- Clock + Date at top -->
    <LinearLayout
        android:id="@+id/layoutClock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="56dp"
        android:paddingBottom="24dp"
        android:layout_alignParentTop="true">

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="h:mm"
            android:format24Hour="HH:mm"
            android:textSize="80sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:letterSpacing="-0.04"
            android:fontFamily="sans-serif-light"/>

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="EEEE, MMMM d"
            android:format24Hour="EEEE, MMMM d"
            android:textSize="15sp"
            android:textColor="#99FFFFFF"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- App Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLauncherApps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomDock"
        android:layout_below="@+id/layoutClock"
        android:paddingHorizontal="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:overScrollMode="never"/>

    <!-- Bottom Dock -->
    <LinearLayout
        android:id="@+id/bottomDock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_alignParentBottom="true"
        android:paddingBottom="28dp"
        android:paddingTop="12dp"
        android:paddingHorizontal="32dp"
        android:background="#00000000">

        <ImageView
            android:id="@+id/ivParentSettings"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@android:drawable/ic_menu_manage"
            android:tint="#88FFFFFF"
            android:padding="12dp"
            android:background="#22FFFFFF"
            android:contentDescription="Settings"/>

    </LinearLayout>

</RelativeLayout>
