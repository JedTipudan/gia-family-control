<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A0A12">

    <!-- Clock -->
    <LinearLayout
        android:id="@+id/layoutClock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="52dp"
        android:paddingBottom="12dp"
        android:layout_alignParentTop="true">

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="h:mm"
            android:format24Hour="HH:mm"
            android:textSize="72sp"
            android:textColor="#FFFFFFFF"
            android:fontFamily="sans-serif-thin"
            android:letterSpacing="-0.04"
            android:includeFontPadding="false"/>

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="EEE, MMM d"
            android:format24Hour="EEE, MMM d"
            android:textSize="13sp"
            android:textColor="#77FFFFFF"
            android:letterSpacing="0.05"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- Search bar -->
    <LinearLayout
        android:id="@+id/layoutSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_below="@id/layoutClock"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingBottom="8dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="Search apps…"
            android:textColorHint="#55FFFFFF"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/search_bar_bg"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawableTint="#77FFFFFF"
            android:drawablePadding="8dp"/>

    </LinearLayout>

    <!-- Bottom dock -->
    <LinearLayout
        android:id="@+id/bottomDock"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_alignParentBottom="true"
        android:paddingBottom="12dp"
        android:paddingHorizontal="40dp">

        <FrameLayout
            android:id="@+id/ivParentSettings"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="#1AFFFFFF">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="#99FFFFFF"/>

        </FrameLayout>

    </LinearLayout>

    <!-- App grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLauncherApps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutSearch"
        android:layout_above="@id/bottomDock"
        android:paddingHorizontal="8dp"
        android:paddingBottom="4dp"
        android:clipToPadding="false"
        android:overScrollMode="never"/>

</RelativeLayout>
