<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#4F46E5"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gia Family Control"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvParentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Parent Dashboard"
                android:textColor="#CCE0E7FF"
                android:textSize="12sp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvPairCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Code: ---"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#3730A3"
            android:padding="6dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"/>

    </LinearLayout>

    <!-- Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1E293B"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvOnlineStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚫ Offline"
            android:textColor="#94A3B8"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvBattery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔋 --%"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvLockStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔓 Unlocked"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:gravity="end"/>

    </LinearLayout>

    <!-- Map -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLock"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🔒 Lock"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="#EF4444"
            app:cornerRadius="10dp"
            android:layout_marginEnd="6dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUnlock"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🔓 Unlock"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="#10B981"
            app:cornerRadius="10dp"
            android:layout_marginEnd="6dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApps"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="📱 Apps"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="#4F46E5"
            app:cornerRadius="10dp"/>

    </LinearLayout>

</LinearLayout>
